# Debtor Query System - Environment Configuration

# Application
APP_NAME=Debtor Query System
VERSION=1.0.0
DEBUG=false

# Database (MySQL)
MYSQL_ROOT_PASSWORD=your_mysql_root_password
MYSQL_DATABASE=debtor_db
MYSQL_USER=debtor_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_PORT=3306

# Backend
BACKEND_PORT=8000

# JWT Authentication
SECRET_KEY=your-super-secret-key-change-in-production-use-strong-random-value-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# SMS Gateway
SMS_GATEWAY_URL=http://sms-mock:8001
SMS_GATEWAY_API_KEY=your-sms-api-key

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Captcha Settings
CAPTCHA_EXPIRE_SECONDS=300
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# H5 API Settings
H5_TOKEN_EXPIRE_DAYS=7
H5_DAILY_QUERY_LIMIT=100

# AES Encryption Key (32 bytes for AES-256)
AES_KEY=your-32-byte-aes-encryption-key-here

# SMS Mock Server
SMS_MOCK_PORT=8001

# Frontend
FRONTEND_PORT=80
